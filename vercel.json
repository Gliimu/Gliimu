{
  "rewrites": [
    {
      "source": "/u/:username",
      "destination": "/frontend/portfolio.html?user=:username"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/user",
      "destination": "/frontend/user.html?user=:username"
    },
    {
      "source": "/display",
      "destination": "/frontend/reader.html"
    },
    {
      "source": "/index",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/hub",
      "destination": "/frontend/hub.html"
    },
    {
      "source": "/library",
      "destination": "/frontend/library.html"
    },
    {
      "source": "/chat",
      "destination": "/frontend/chat.html"
    },
    {
      "source": "/virtualroom",
      "destination": "/frontend/virtualroom.html"
    },
    {
      "source": "/faq",
      "destination": "/frontend/faq.html"
    },
    {
      "source": "/contact",
      "destination": "/frontend/contact.html"
    },
    {
      "source": "/application",
      "destination": "/frontend/application.html"
    },
    {
      "source": "/signin",
      "destination": "/frontend/signin.html"
    },
    {
      "source": "/signup",
      "destination": "/frontend/signup.html"
    },
    {
      "source": "/portfolio",
      "destination": "/frontend/portfolio.html"
    },
    {
      "source": "/course",
      "destination": "/frontend/course.html"
    },
    {
      "source": "/admin",
      "destination": "/frontend/admin-dashboard.html"
    },
    {
      "source": "/:path*/:file(.*)",
      "destination": "/frontend/:path*/:file"
    }
  ],
  "redirects": [
    {
      "source": "/hub.html",
      "destination": "/hub",
      "permanent": true
    },
    {
      "source": "/reader.html",
      "destination": "/display",
      "permanent": true
    },
    {
      "source": "/chat.html",
      "destination": "/chat",
      "permanent": true
    },
    {
      "source": "/virtualroom.html",
      "destination": "/virtualroom",
      "permanent": true
    },
    {
      "source": "/user.html",
      "destination": "/user/:username",
      "permanent": true
    },
    {
      "source": "/faq.html",
      "destination": "/faq",
      "permanent": true
    },
    {
      "source": "/contact.html",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/application.html",
      "destination": "/application",
      "permanent": true
    },
    {
      "source": "/signin.html",
      "destination": "/signin",
      "permanent": true
    },
    {
      "source": "/signup.html",
      "destination": "/signup",
      "permanent": true
    },
    {
      "source": "/portfolio.html",
      "destination": "/portfolio",
      "permanent": true
    },
    {
      "source": "/course.html",
      "destination": "/course",
      "permanent": true
    },
    {
      "source": "/admin-dashboard.html",
      "destination": "/admin",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(jpg|jpeg|png|gif|ico|svg|css|js|woff|woff2|ttf|eot)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
